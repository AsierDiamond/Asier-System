PRINT("Welcome to Asier System! Write 'help' for commands.");PRINT("\n");CREATEVAR("a");SETVAR("a","0");CREATEVAR("w");SETVAR("w","0");LOOP;	ASK(">");	SETVAR("a","!last_answer!");	IF("%a%==help");		PRINT("exe : Run an ASPL executable");		PRINT("\n");		PRINT("time : Prints the time and date in YYYY/DD/MM");		PRINT("\n");		PRINT("battery : Prints the battery the device has left);		PRINT("\n");		PRINT("info : Prints info about Asier System");		PRINT("\n");		PRINT("download : Downloads a url into the file system");		PRINT("\n");		PRINT("file : Manage the file system");		PRINT("\n");		PRINT("cf : Create a new file");		PRINT("\n");		PRINT("rf : Read a file");		PRINT("\n");		PRINT("df : Delete a file");		PRINT("\n");		PRINT("wf : Write into a file");		PRINT("\n");		PRINT("cd" : Create a directory);		PRINT("\n");		PRINT("dd : Delete a directory");		PRINT("\n");	ENDIF;	IF("%a%==time");		PRINT("The current time is !time!");		PRINT("\n");	ENDIF;	IF("%a%==battery");		PRINT("The device has a !battery!% left of battery");		PRINT("\n");	ENDIF;	IF("%a%==info");		CLEARCANVAS 		PRINT(">info");		PRINT("\n");		PRINT("      @@@@@@@@@@      Asier System version: !version!");		PRINT("\n");		PRINT("   @@@+        +@@@    Host browser: !hostbrowser!");		PRINT("\n");		PRINT("  @@    +=.       @@     Architecture: !arch!");		PRINT("\n");		PRINT("@@#    @  #        #@@ CPU cores: !core!");		PRINT("\n");		PRINT("@@    @   .@#**=.   @@  Host OS: !hostos!");		PRINT("\n");		PRINT("@+   @   %=@        +@  Platform: !platform!");		PRINT("\n");		PRINT("@+  :+   *-@+++     +@ Build: !build!");		PRINT("\n");		PRINT("@@  @      @  =+    @@");		PRINT("\n");		PRINT(" @#        @-#=    #@ ");		PRINT("\n");		PRINT("  @@    =+-:      @@  ");		PRINT("\n");		PRINT("   @@@:        :@@@   ");		PRINT("\n");		PRINT("     @@@@@@@@@@     ");		PRINT("\n");	ENDIF;	IF("%a%==download");		PRINT("Type the url you want to download");		PRINT("\n");		ASK(">");		GET("!last_answer!");		WAIT("0.2");		PRINT("Type the file name");		PRINT("\n");		ASK(">");		CREATEFILE("!last_answer!");		WRITE("!last_fetch!","!last_answer!");		PRINT("Writing file");		WAIT("0");		PRINT(".");		WAIT("0");		PRINT(".");		WAIT("0");		PRINT(".");		PRINT("\n");	ENDIF;	IF("%a%==CF");		PRINT("Gotcha, type the name of the file you want to create please, include Directories");		PRINT("\n");		ASK(">");		CREATEFILE("!last_answer!");	ENDIF;	IF("%a%==DF");		PRINT("Okay! Please type the name of the file you want to delete, include Directories");		PRINT("\n");		ASK(">");		DELETEFILE("!last_answer!");	ENDIF;	IF("%a%==WF");		PRINT("Let's get writin'!, which file do you want to write?, include Directories");		PRINT("\n");		ASK(">");		SETVAR("w","!last_answer!");		PRINT("You are writing at the file !last_answer!");		PRINT("\n");		ASK(">");		PRINT("Finished writing file");		PRINT("\n");		WRITE("!last_answer!","%w%");		WAIT("0.1");	ENDIF;	IF("%a%==RF");		PRINT("Okay! Please input the name of the file you want to read, include Directories");		PRINT("\n");		ASK(">");		GETFILEDATA("data","!last_answer!");		PRINT("!last_file!");		PRINT("\n");	ENDIF;	IF("%a%==CD");		PRINT("Gotcha, type the name of the directory you want to create please.");		PRINT("\n");		ASK(">");		CREATEDIR("!last_answer!");	ENDIF;	IF("%a%==DD");		PRINT("Okay! Please type the name of the directory.");		PRINT("\n");		ASK(">");		DELETEDIR("!last_answer!");	ENDIF;	IF("%a%==exe");	PRINT("Please type the name of the ASPL file you want to run (include Directories)");	PRINT("\n");	ASK(">");	PRINT("Cya!");	WAIT("0.1");	EXECUTE("!last_answer!");ENDLOOP
